# PostgreSQL z Supabase albo Neon. Format dla Prisma zwykle:
# postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Wygeneruj: openssl rand -base64 32
AUTH_SECRET="wklej_wygenerowany_secret"
NEXTAUTH_SECRET="wklej_ten_sam_secret_dla_kompatybilnosci"

# Lokalnie: http://localhost:3000
# Produkcja: https://twoja-aplikacja.vercel.app
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Opcjonalny sekret dla cron endpointu /api/recurring/run
CRON_SECRET="zmien_mnie"

# Opcjonalnie oddzielny klucz AES-256 dla tokenów PSD2/Open Banking.
# Jeśli brak, aplikacja wyprowadzi klucz z AUTH_SECRET.
# Wygeneruj: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BANK_TOKEN_ENCRYPTION_KEY="wklej_base64_32_bajty"
